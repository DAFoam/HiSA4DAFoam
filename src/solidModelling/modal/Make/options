MAJ_VER := $(WM_PROJECT_VERSION:v%=%)
MAJ_VER := $(subst ., ,$(MAJ_VER))
MAJ_VER := $(word 1,$(MAJ_VER))

ifeq ($(shell expr $(MAJ_VER) \>= 1000), 1)
    ifeq ($(shell expr $(MAJ_VER) \>= 1712), 1)
        FOAM_VERSION = -DFOAM_VERSION_1712
    endif
else
    ifeq ($(shell expr $(WM_PROJECT_VERSION) \>= 6), 1)
        FOAM_VERSION = -DFOAM_VERSION_6
    endif
    ifeq ($(shell expr $(WM_PROJECT_VERSION) \< 5), 1)
        FOAM_VERSION = -DFOAM_VERSION_4
    endif
endif

ifeq (OpenFOAM-dev,$(findstring OpenFOAM-dev,$(WM_PROJECT_DIR)))
    FOAM_VERSION = -DFOAM_VERSION_6
endif
ifeq (OpenFOAM-plus,$(findstring OPENFOAM-plus,$(WM_PROJECT_DIR)))
    FOAM_VERSION = -DFOAM_VERSION_1706
endif

ifdef BLUECFDPATH
    BLUECFD = -DBLUECFD
endif

EXE_INC = -g \
    $(FOAM_VERSION) \
    $(BLUECFD) \
    -IlnInclude \
    -I$(LIB_SRC)/finiteVolume/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude \
    -I$(LIB_SRC)/fileFormats/lnInclude \
    -I$(LIB_SRC)/transportModels \
    -I$(LIB_SRC)/transportModels/compressible/lnInclude \
    -I$(LIB_SRC)/TurbulenceModels/turbulenceModels/lnInclude \
    -I$(LIB_SRC)/TurbulenceModels/incompressible/lnInclude \
    -I$(LIB_SRC)/TurbulenceModels/compressible/lnInclude \
    -I$(LIB_SRC)/thermophysicalModels/basic/lnInclude \
    -I$(LIB_SRC)/surfMesh/lnInclude \
    -I$(LIB_SRC)/ODE/lnInclude \
    -I$(LIB_SRC)/OpenFOAM/lnInclude

LIB_LIBS = \
    -lODE \
    -lcompressibleTransportModels \
    -lturbulenceModels \
    -lincompressibleTurbulenceModels \
    -lcompressibleTurbulenceModels \
    -lincompressibleTransportModels \
    -lfluidThermophysicalModels \
    -lspecie \
    -lfiniteVolume \
    -lmeshTools \
    -lfileFormats \
    -L$(FOAM_USER_LIBBIN) \
    -lhisaFiniteVolume
