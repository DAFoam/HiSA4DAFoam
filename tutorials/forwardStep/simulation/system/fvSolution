FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers {}

flowSolver
{
    solver            GMRES;
    GMRES
    {
        inviscidJacobian  LaxFriedrich;
        preconditioner    LUSGS;
        maxIter           30;
        nKrylov           4;
        solverTolRel      1e-1 (1e-1 1e-1 1e-1) 1e-1;
    }
}

pseudoTime
{
    nPseudoCorr       20;
    pseudoTol         1e-3 (1e-3 1e-3 1e-3) 1e-3;
    pseudoCoNum       2.0;
    pseudoCoNumMax    100.0;
}


